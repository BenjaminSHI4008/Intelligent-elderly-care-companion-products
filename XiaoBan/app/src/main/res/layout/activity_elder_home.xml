<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_elder_home">

    <!-- 顶部信息栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5月10日 星期六"
                android:textSize="20sp"
                android:textColor="#666666" />

            <TextView
                android:id="@+id/tv_weather"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="多云 18°C"
                android:textSize="16sp"
                android:textColor="#888888" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_profile"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_xiaoban_avatar"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center">

            <TextView
                android:id="@+id/tv_profile_initial"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="伴"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

    <!-- 消息卡片 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="12dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📬 家人消息"
                    android:textSize="22sp"
                    android:textColor="#2B7A78"
                    android:textStyle="bold" />

                <View
                    android:id="@+id/unread_dot"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/bg_unread_dot"
                    android:visibility="gone" />

            </LinearLayout>

            <TextView
                android:id="@+id/tv_message_preview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="女儿发来一条语音消息"
                android:textSize="18sp"
                android:textColor="#666666" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- 绑定家人卡片 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_bind"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="10dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🔗 绑定家人"
                android:textSize="22sp"
                android:textColor="#2B7A78"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_bind_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="查看绑定码 ›"
                android:textSize="18sp"
                android:textColor="#888888" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- AI聊天记录入口 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_ai_chat_history"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="10dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🤖 AI聊天记录"
                android:textSize="22sp"
                android:textColor="#2B7A78"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="查看与小伴的历史对话"
                android:textSize="18sp"
                android:textColor="#666666" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- 欢迎气泡 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/welcome_bubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp"
        android:visibility="gone"
        app:cardCornerRadius="20dp"
        app:cardElevation="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:text="您好！我是小伴，有什么想聊的吗？"
            android:textSize="20sp"
            android:textColor="#2B7A78" />

    </androidx.cardview.widget.CardView>

    <!-- 中间空白区域和语音按钮 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">

            <androidx.cardview.widget.CardView
                android:id="@+id/voice_button_card"
                android:layout_width="180dp"
                android:layout_height="180dp"
                app:cardCornerRadius="90dp"
                app:cardElevation="24dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_voice_button_normal">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_microphone"
                            android:contentDescription="麦克风" />

                        <TextView
                            android:id="@+id/tv_voice_hint"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="按住说话"
                            android:textColor="@color/white"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </FrameLayout>

            </androidx.cardview.widget.CardView>

            <com.xiaoban.app.widget.VoiceButton
                android:id="@+id/voice_button"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_marginTop="-180dp"
                android:background="@android:color/transparent" />

        </LinearLayout>

    </FrameLayout>

    <!-- 紧急呼叫按钮 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="20dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="12dp">

        <LinearLayout
            android:id="@+id/btn_emergency"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@drawable/bg_emergency_button_gradient"
            android:gravity="center"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🆘 紧急呼叫"
                android:textColor="@color/white"
                android:textSize="26sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>
